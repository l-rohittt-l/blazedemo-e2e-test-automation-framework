<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="BlazeDemo E2E Suite" verbose="1" thread-count="1" parallel="none">

    <listeners>
        <listener class-name="listeners.ScreenshotListener"/>
    </listeners>

    <test name="Flight Booking Tests">
        <classes>
            <class name="tests.FlightBookingTest"/>
        </classes>
    </test>

    <test name="Flight Booking Negative Tests">
        <classes>
            <class name="tests.FlightBookingNegativeTest"/>
        </classes>
    </test>

</suite>
